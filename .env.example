# ============================================================
# .env.example - Molde de Variáveis de Ambiente
# COPIE este arquivo para .env e preencha com seus dados reais
# ============================================================

# Credenciais Google OAuth2 (Google Auth Platform)
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=sua_secret_aqui
# Após preencher os dois acima, rode "node get-token.js" para gerar o abaixo automaticamente:
GOOGLE_REFRESH_TOKEN=

# IDs do Workspace
DRIVE_FOLDER_ID=id_da_pasta_no_drive
SHEET_ID=id_da_planilha_no_sheets

# Disparo de Emails Auto (Gmail)
GMAIL_USER=seu_email_remetente@gmail.com
GMAIL_APP_PASSWORD=senha_de_app_de_16_caracteres_gerada_no_google

# Professora (E-mail que recebe os avisos)
PROFESSOR_EMAIL=email_professora@gmail.com
PROFESSOR_NAME=Professora Roberta Cardoso

# Painel Administrativo do Site (/admin)
ADMIN_PASSWORD=senha_super_forte_para_admin
