# =============================================================
# Variáveis de Ambiente — Copie para .env (nunca suba no git!)
# =============================================================

# Credenciais do Service Account do Google Cloud (JSON em base64)
# Como gerar: cat service-account.json | base64
GOOGLE_CREDENTIALS=

# ID da pasta no Google Drive da professora
# Ex: https://drive.google.com/drive/folders/ESTE_ID_AQUI
DRIVE_FOLDER_ID=

# ID da Google Sheets para log de submissões
# Ex: https://docs.google.com/spreadsheets/d/ESTE_ID_AQUI
SHEET_ID=

# Gmail para envio de e-mails (conta do remetente)
GMAIL_USER=professora@gmail.com

# App Password do Gmail (gerado em myaccount.google.com > Segurança > Senhas de app)
GMAIL_APP_PASSWORD=

# E-mail da professora para receber notificações de cada entrega
PROFESSOR_EMAIL=professora@gmail.com

# Nome da professora (aparece nos e-mails e no rodapé da página)
PROFESSOR_NAME=Professora Roberta

# Senha para acessar o painel administrativo
ADMIN_PASSWORD=senha-segura-aqui
